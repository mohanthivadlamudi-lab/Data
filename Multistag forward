#include <stdio.h>
#define INF 9999

int main() {
    int cost[4][4] = {
        {0, 2, 1, 0},
        {0, 0, 3, 4},
        {0, 0, 0, 2},
        {0, 0, 0, 0}
    };

    int dist[4] = {0, INF, INF, INF};
    int i, j;

    for(i = 0; i < 4; i++) {
        for(j = 0; j < 4; j++) {
            if(cost[i][j] != 0) {
                if(dist[j] > dist[i] + cost[i][j]) {
                    dist[j] = dist[i] + cost[i][j];
                }
            }
        }
    }

    printf("Minimum cost: %d", dist[3]);
}
